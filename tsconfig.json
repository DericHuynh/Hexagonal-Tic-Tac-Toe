{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@hex/game-core": ["./packages/game-core/src/index.ts"],
      "@hex/db": ["./packages/db/src/index.ts"],
      "@hex/ui": ["./packages/ui/src/index.ts"],
    },
    "composite": true,
    "outDir": "./dist",
  },
  "files": [],
  "references": [
    { "path": "./apps/web" },
    { "path": "./packages/db" },
    { "path": "./packages/game-core" },
    { "path": "./packages/ui" },
  ],
}
