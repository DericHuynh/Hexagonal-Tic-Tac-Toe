{
  "name": "hex-tic-tac-toe",
  "private": true,
  "sideEffects": false,
  "license": "LGPL-3.0-only",
  "author": "Cloudflare, Inc. (https://cloudflare.com)",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "serve": "pnpm --filter web serve",
    "test": "vitest run",
    "test:game-core": "pnpm --filter game-core test",
    "deploy": "pnpm --filter web deploy",
    "preview": "pnpm --filter web preview",
    "db:generate": "pnpm --filter web db:generate",
    "db:generate:do": "pnpm --filter web db:generate:do",
    "db:migrate": "pnpm --filter web db:migrate",
    "cf-typegen": "pnpm --filter web cf-typegen",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.14",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "turbo": "^2.8.19",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.2.4",
    "wrangler": "^4.67.0"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ],
    "overrides": {
      "esbuild": "0.25.1"
    }
  }
}
