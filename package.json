{
  "name": "hex-tic-tac-toe",
  "private": true,
  "license": "LGPL-3.0-only",
  "author": "Cloudflare, Inc. (https://cloudflare.com)",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "sideEffects": false,
  "scripts": {
    "setup": "vp install",
    "dev": "vp run --filter web dev",
    "build": "vp run --filter web build",
    "serve": "vp run --filter web serve",
    "test": "vp run -r test",
    "test:game-core": "vp run --filter game-core test",
    "test:e2e": "vp run --filter web-e2e test",
    "test:all": "vp run -r test && vp run --filter web-e2e test",
    "check": "vp run -r check",
    "lint": "vp run -r lint",
    "fmt": "vp fmt",
    "verify": "vp check && vp run test:all",
    "deploy": "vp run --filter web deploy",
    "preview": "vp run --filter web preview",
    "db:generate": "vp run --filter web db:generate",
    "db:generate:do": "vp run --filter web db:generate:do",
    "db:migrate": "vp run --filter web db:migrate",
    "cf-typegen": "vp run --filter web cf-typegen",
    "typecheck": "vp run -r typecheck",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "typescript": "catalog:",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.12",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.12",
    "wrangler": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  }
}